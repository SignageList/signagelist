{
	"$schema": "https://biomejs.dev/schemas/2.4.0/schema.json",
	"files": {
		"includes": ["assets/ts/**/*.ts", "scripts/**/*.ts", "cli.ts"]
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"linter": {
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	}
}
